{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: go run",
      "type": "shell",
      "command": "$env:AIP_DATA_FOLDER='${workspaceFolder}\\data'; try { Invoke-WebRequest -UseBasicParsing http://127.0.0.1:8080/ | Out-Null; Write-Host 'Backend ready on http://127.0.0.1:8080'; Write-Host 'Using existing backend process. Stop that process if you need a fresh backend.'; while ($true) { Start-Sleep -Seconds 3600 } } catch { Write-Host 'Backend starting on http://127.0.0.1:8080'; Write-Host \"AIP_DATA_FOLDER=$env:AIP_DATA_FOLDER\"; go run . }",
      "options": {
        "cwd": "${workspaceFolder}/cmd/aip_food_lookup",
        "shell": {
          "executable": "powershell.exe",
          "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Backend (ready|starting)",
          "endsPattern": "Backend (ready|starting)"
        }
      },
      "presentation": {
        "group": "local",
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "backend: wait for ready",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$deadline = (Get-Date).AddSeconds(30); do { try { Invoke-WebRequest -UseBasicParsing http://127.0.0.1:8080/ | Out-Null; Write-Host 'Backend responded on http://127.0.0.1:8080'; exit 0 } catch { Start-Sleep -Milliseconds 500 } } while ((Get-Date) -lt $deadline); Write-Error 'Backend did not become ready on http://127.0.0.1:8080 within 30 seconds. Check whether port 8080 is blocked or another process is failing to start.'; exit 1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": []
    },
    {
      "label": "flutter: pub get",
      "type": "process",
      "command": "C:\\dev\\flutter\\bin\\flutter.bat",
      "args": [
        "pub",
        "get"
      ],
      "options": {
        "cwd": "${workspaceFolder}/flutter-app"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: pnpm install",
      "type": "process",
      "command": "corepack",
      "args": [
        "pnpm",
        "install",
        "--frozen-lockfile"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: dev",
      "type": "process",
      "command": "corepack",
      "args": [
        "pnpm",
        "run",
        "dev",
        "--",
        "--host",
        "127.0.0.1",
        "--port",
        "5173"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "group": "local",
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "frontend: wait for ready",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$deadline = (Get-Date).AddSeconds(30); do { try { Invoke-WebRequest -UseBasicParsing http://127.0.0.1:5173/ | Out-Null; Write-Host 'Frontend responded on http://127.0.0.1:5173'; exit 0 } catch { Start-Sleep -Milliseconds 500 } } while ((Get-Date) -lt $deadline); Write-Error 'Frontend did not become ready on http://127.0.0.1:5173 within 30 seconds.'; exit 1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": []
    },
    {
      "label": "local: prepare phone launch",
      "dependsOn": [
        "backend: go run",
        "backend: wait for ready",
        "flutter: pub get"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "local: prepare web launch",
      "dependsOn": [
        "backend: go run",
        "backend: wait for ready",
        "frontend: pnpm install",
        "frontend: dev",
        "frontend: wait for ready"
      ],
      "dependsOrder": "sequence"
    }
  ]
}
