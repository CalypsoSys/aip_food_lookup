{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Galaxy S23",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/flutter-app/lib/main.dart",
      "cwd": "${workspaceFolder}/flutter-app",
      "deviceId": "RFCWC06KQGF",
      "toolArgs": [
        "--dart-define-from-file",
        "${workspaceFolder}/.vscode/aip-local.env"
      ],
      "preLaunchTask": "local: prepare phone launch",
      "presentation": {
        "group": "local",
        "order": 1
      }
    },
    {
      "name": "_web_frontend_internal",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "preLaunchTask": "local: prepare web launch",
      "presentation": {
        "group": "local",
        "order": 2,
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "Local: frontend + API",
      "configurations": [
        "_web_frontend_internal"
      ],
      "presentation": {
        "group": "local",
        "order": 1
      }
    }
  ]
}
